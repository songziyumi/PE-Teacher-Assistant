# =========================
# PE Teacher Assistant
# Tencent SES API Example
# =========================

DB_PASSWORD=replace-with-your-db-password
APP_ADMIN_DEFAULT_PASSWORD=replace-with-your-admin-password
APP_SUPER_ADMIN_DEFAULT_PASSWORD=replace-with-your-super-admin-password
APP_JWT_SECRET=replace-with-a-long-random-jwt-secret
APP_UPLOAD_DIR=/opt/pe-assistant/uploads

APP_MAIL_ENABLED=true
APP_MAIL_TRANSPORT=ses-api
APP_MAIL_PRODUCT_NAME=体育教师助手
APP_MAIL_FROM=no-reply@your-domain.com
APP_MAIL_BASE_URL=https://your-domain.com
APP_MAIL_DISPATCH_ENABLED=true
APP_MAIL_DISPATCH_BATCH_SIZE=20
APP_MAIL_DISPATCH_FIXED_DELAY_MS=30000
APP_MAIL_MAX_RETRY_COUNT=3
APP_MAIL_RETRY_DELAY_MINUTES=5
APP_MAIL_VERIFY_EXPIRE_MINUTES=30
APP_MAIL_RESET_EXPIRE_MINUTES=30
APP_MAIL_VERIFY_LIMIT_PER_ACCOUNT=3
APP_MAIL_VERIFY_LIMIT_PER_IP=10
APP_MAIL_RESET_LIMIT_PER_ACCOUNT=3
APP_MAIL_RESET_LIMIT_PER_IP=10

SPRING_MAIL_HOST=
SPRING_MAIL_PORT=465
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROTOCOL=smtp
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=false
SPRING_MAIL_SMTP_STARTTLS_REQUIRED=false
SPRING_MAIL_SMTP_SSL_ENABLE=true
SPRING_MAIL_SMTP_CONNECTION_TIMEOUT=5000
SPRING_MAIL_SMTP_TIMEOUT=10000
SPRING_MAIL_SMTP_WRITE_TIMEOUT=10000

APP_MAIL_SES_API_SECRET_ID=replace-with-your-secret-id
APP_MAIL_SES_API_SECRET_KEY=replace-with-your-secret-key
APP_MAIL_SES_API_REGION=ap-guangzhou
APP_MAIL_SES_API_ENDPOINT=ses.tencentcloudapi.com
APP_MAIL_SES_API_REPLY_TO_ADDRESS=
APP_MAIL_SES_API_TRIGGER_TYPE=1
APP_MAIL_SES_API_VERIFY_EMAIL_TEMPLATE_ID=10001
APP_MAIL_SES_API_RESET_PASSWORD_TEMPLATE_ID=10002
