page {
  background: #f4f7fb;
  color: #1f2937;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx 24rpx 48rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, #d7e8ff 0, #f4f7fb 35%),
    linear-gradient(180deg, #eef4fb 0%, #f7f9fc 100%);
}

.hero-card,
.panel-card {
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(22, 50, 79, 0.08);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 48rpx rgba(22, 50, 79, 0.08);
}

.hero-card {
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
}

.panel-card {
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #16324f;
}

.page-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #5c6b7a;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #16324f;
}

.section-caption {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #7b8794;
}

.primary-button {
  background: linear-gradient(135deg, #16324f 0%, #265d8c 100%);
  color: #ffffff;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 6rpx 0;
}

.secondary-button {
  background: #ffffff;
  color: #16324f;
  border: 1rpx solid rgba(22, 50, 79, 0.18);
  border-radius: 20rpx;
  font-size: 28rpx;
}

.muted-text {
  color: #7b8794;
}

.empty-text {
  font-size: 24rpx;
  color: #7b8794;
  line-height: 1.7;
}
