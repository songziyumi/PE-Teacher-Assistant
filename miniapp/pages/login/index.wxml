<view class="page-shell">
  <view class="hero-card login-hero">
    <view class="page-title">体育教师助手</view>
    <view class="page-subtitle">使用教师账号登录，进入小程序工作台。</view>
  </view>

  <view class="panel-card">
    <view class="field-label">账号</view>
    <input
      class="input-field"
      placeholder="请输入账号"
      value="{{username}}"
      bindinput="onUsernameInput"
    />

    <view class="field-label">密码</view>
    <input
      class="input-field"
      password="{{true}}"
      placeholder="请输入密码"
      value="{{password}}"
      bindinput="onPasswordInput"
    />

    <view wx:if="{{errorMessage}}" class="error-box">{{errorMessage}}</view>

    <button class="primary-button login-button" loading="{{loading}}" bindtap="handleLogin">
      登录
    </button>
  </view>
</view>
