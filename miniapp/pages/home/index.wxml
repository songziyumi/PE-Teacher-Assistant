<view class="page-shell">
  <view class="hero-card home-hero">
    <view class="hero-top">
      <view>
        <view wx:if="{{user}}" class="page-title">{{user.name}}</view>
        <view wx:else class="page-title">{{text.workbench}}</view>
        <view class="page-subtitle">
          {{user ? user.role : ''}}
          <text wx:if="{{user && user.schoolName}}"> &#183; {{user.schoolName}}</text>
        </view>
      </view>
      <view class="hero-actions" wx:if="{{isTeacher}}">
        <button class="secondary-button small-button" bindtap="goTeacherProfile">{{text.profile}}</button>
        <button class="secondary-button small-button" bindtap="handleLogout">{{text.logout}}</button>
      </view>
      <button wx:elif="{{user}}" class="secondary-button small-button" bindtap="handleLogout">{{text.logout}}</button>
    </view>
  </view>

  <view wx:if="{{loading}}" class="panel-card">
    <view class="empty-text">{{text.loading}}</view>
  </view>

  <view wx:elif="{{errorMessage}}" class="panel-card">
    <view class="section-title">{{text.loadFailed}}</view>
    <view class="page-subtitle">{{errorMessage}}</view>
    <button class="primary-button" bindtap="handleRefresh">{{text.reload}}</button>
  </view>

  <block wx:else>
    <view wx:if="{{isStudent}}" class="panel-card">
      <view class="section-title">{{text.studentSummary}}</view>
      <view class="metrics-grid">
        <view class="metric-box">
          <view class="metric-value">{{home.currentCourseCount || 0}}</view>
          <view class="metric-label">{{text.currentCourseCount}}</view>
        </view>
        <view class="metric-box">
          <view class="metric-value">{{home.confirmedCourseCount || 0}}</view>
          <view class="metric-label">{{text.confirmedCourseCount}}</view>
        </view>
        <view class="metric-box">
          <view class="metric-value">{{home.pendingSelectionCount || 0}}</view>
          <view class="metric-label">{{text.pendingSelectionCount}}</view>
        </view>
        <view class="metric-box">
          <view class="metric-value">{{home.unreadMessageCount || 0}}</view>
          <view class="metric-label">{{text.unreadMessageCount}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{isTeacher}}" class="panel-card">
      <view class="section-title">{{text.teacherSummary}}</view>
      <view class="metrics-grid">
        <view class="metric-box">
          <view class="metric-value">{{home.classCount || 0}}</view>
          <view class="metric-label">{{text.classCount}}</view>
        </view>
        <view class="metric-box">
          <view class="metric-value">{{home.pendingCourseRequestCount || 0}}</view>
          <view class="metric-label">{{text.pendingCourseRequestCount}}</view>
        </view>
        <view class="metric-box">
          <view class="metric-value">{{home.unreadMessageCount || 0}}</view>
          <view class="metric-label">{{text.unreadMessageCount}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{home.currentEvent}}" class="panel-card">
      <view class="section-title">{{text.currentEvent}}</view>
      <view class="info-row">
        <text class="info-label">{{text.eventName}}</text>
        <text class="info-value">{{home.currentEvent.name}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">{{text.eventStatus}}</text>
        <text class="info-value">{{home.currentEvent.status}}</text>
      </view>
    </view>

    <view wx:if="{{isTeacher && home.classes && home.classes.length}}" class="panel-card">
      <view class="section-title">{{text.myClasses}}</view>
      <view class="tag-list">
        <view wx:for="{{home.classes}}" wx:key="id" class="tag-item">
          <view class="tag-name">{{item.name}}</view>
          <view wx:if="{{item.gradeName || item.type}}" class="tag-meta">
            <text wx:if="{{item.gradeName}}">{{item.gradeName}}</text>
            <text wx:else>{{text.noGrade}}</text>
            <text> &#183; </text>
            <text wx:if="{{item.type}}">{{item.type}}</text>
            <text wx:else>{{text.classType}}</text>
          </view>
          <view class="class-action-grid">
            <view class="class-action-button class-action-button-primary" data-class-id="{{item.id}}" data-class-name="{{item.name}}" bindtap="goTeacherAttendanceForClass">{{text.attendanceEntry}}</view>
            <view class="class-action-button class-action-button-secondary" data-class-id="{{item.id}}" data-class-name="{{item.name}}" bindtap="goTeacherStudentList">{{text.studentList}}</view>
            <view class="class-action-button class-action-button-secondary" data-label="{{text.physicalEntry}}" bindtap="showTodoFeature">{{text.physicalEntry}}</view>
            <view class="class-action-button class-action-button-secondary" data-label="{{text.gradeEntry}}" bindtap="showTodoFeature">{{text.gradeEntry}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="panel-card">
      <view class="section-title">{{text.recentMessages}}</view>
      <view wx:if="{{home.recentMessages && home.recentMessages.length}}">
        <view wx:for="{{home.recentMessages}}" wx:key="id" class="message-item">
          <view wx:if="{{item.subject}}" class="message-subject">{{item.subject}}</view>
          <view wx:else class="message-subject">{{text.unnamedMessage}}</view>
          <view class="message-meta">
            <text wx:if="{{item.senderName}}">{{item.senderName}}</text>
            <text wx:else>{{text.system}}</text>
            <text wx:if="{{item.sentAt}}"> &#183; {{item.sentAt}}</text>
          </view>
        </view>
      </view>
      <view wx:else class="empty-text">{{text.noRecentMessages}}</view>
    </view>

    <view wx:if="{{isTeacher && home.recentActivities && home.recentActivities.length}}" class="panel-card">
      <view class="section-title">{{text.recentActivities}}</view>
      <view wx:for="{{home.recentActivities}}" wx:key="index" class="message-item">
        <view class="message-subject">{{item.title || item.action}}</view>
        <view class="message-meta">{{item.description || '-'}}</view>
      </view>
    </view>
  </block>
</view>
