.home-hero {
  background:
    linear-gradient(140deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.92)),
    #ffffff;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 10rpx;
  flex: none;
}

.small-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: none;
  min-width: 0;
  width: auto !important;
  max-width: none;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 12rpx;
  font-size: 22rpx;
  border-radius: 14rpx;
  margin: 0;
  white-space: nowrap;
  box-sizing: border-box;
}

.small-button::after {
  border: 0;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 22rpx;
}

.metric-box {
  padding: 24rpx 20rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #eef5fb 100%);
}

.metric-value {
  font-size: 42rpx;
  font-weight: 700;
  color: #16324f;
}

.metric-label {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #64748b;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(22, 50, 79, 0.08);
}

.info-row:last-child {
  border-bottom: 0;
}

.info-label {
  font-size: 24rpx;
  color: #64748b;
}

.info-value {
  flex: 1;
  text-align: right;
  font-size: 24rpx;
  color: #16324f;
  font-weight: 600;
}

.tag-list {
  margin-top: 18rpx;
}

.tag-item {
  padding: 20rpx 22rpx;
  margin-bottom: 14rpx;
  border-radius: 20rpx;
  background: #f7fbff;
  border: 1rpx solid rgba(22, 50, 79, 0.08);
}

.tag-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #16324f;
}

.tag-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.class-action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.class-action-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  width: 100%;
  height: auto;
  min-height: 60rpx;
  line-height: 1.3;
  padding: 10rpx 8rpx;
  margin: 0;
  border-radius: 16rpx;
  font-size: 22rpx;
  box-sizing: border-box;
  white-space: normal;
  text-align: center;
  word-break: break-word;
  overflow: hidden;
}

.class-action-button-primary {
  background: linear-gradient(135deg, #16324f 0%, #265d8c 100%);
  color: #ffffff;
}

.class-action-button-secondary {
  background: #ffffff;
  color: #16324f;
  border: 1rpx solid rgba(22, 50, 79, 0.18);
}

.message-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(22, 50, 79, 0.08);
}

.message-item:last-child {
  border-bottom: 0;
}

.message-subject {
  font-size: 26rpx;
  color: #16324f;
  font-weight: 600;
}

.message-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6b7280;
}
