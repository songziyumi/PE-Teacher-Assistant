.hero-meta-pill {
  display: inline-flex;
  margin-top: 22rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #16324f;
  font-size: 22rpx;
}

.overview-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 8rpx 4rpx 16rpx;
}

.overview-count {
  font-size: 30rpx;
  font-weight: 700;
  color: #16324f;
}

.overview-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.overview-card {
  padding: 22rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(22, 50, 79, 0.08);
  box-shadow: 0 12rpx 28rpx rgba(22, 50, 79, 0.06);
}

.overview-inline-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.overview-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #16324f;
}

.overview-gender {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(22, 50, 79, 0.08);
  color: #16324f;
  font-size: 20rpx;
}

.overview-no {
  font-size: 22rpx;
  color: #64748b;
}

.overview-score-value {
  margin-left: auto;
  font-size: 30rpx;
  font-weight: 700;
  color: #16324f;
}

.overview-level {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.4;
}

.overview-view-link {
  font-size: 22rpx;
  color: #2563eb;
  font-weight: 600;
}

.level-excellent {
  color: #16a34a;
  background: rgba(34, 197, 94, 0.14);
}

.level-good {
  color: #2563eb;
  background: rgba(37, 99, 235, 0.14);
}

.level-pass {
  color: #d97706;
  background: rgba(245, 158, 11, 0.16);
}

.level-fail {
  color: #dc2626;
  background: rgba(239, 68, 68, 0.14);
}

.level-empty {
  color: #64748b;
  background: rgba(100, 116, 139, 0.12);
}
