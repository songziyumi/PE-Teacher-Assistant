<view class="page-shell">
  <view class="hero-card student-hero">
    <view wx:if="{{className}}" class="page-title">{{className}}</view>
    <view wx:else class="page-title">{{text.defaultTitle}}</view>
    <view class="page-subtitle">{{text.subtitle}}</view>
    <view class="stats-row">
      <view class="stat-pill">
        <text class="stat-pill-value">{{totalCount}}</text>
        <text class="stat-pill-label">{{text.totalCount}}</text>
      </view>
      <view class="stat-pill">
        <text class="stat-pill-value">{{maleCount}}</text>
        <text class="stat-pill-label">{{text.maleCount}}</text>
      </view>
      <view class="stat-pill">
        <text class="stat-pill-value">{{femaleCount}}</text>
        <text class="stat-pill-label">{{text.femaleCount}}</text>
      </view>
    </view>
  </view>

  <view class="panel-card">
    <view class="section-title">{{text.filters}}</view>
    <input
      class="search-input"
      placeholder="{{text.searchPlaceholder}}"
      value="{{keyword}}"
      confirm-type="search"
      bindinput="onKeywordInput"
      bindconfirm="submitSearch"
    />
    <picker mode="selector" range="{{statusOptions}}" value="{{statusIndex}}" bindchange="onStatusChange">
      <view class="picker-field">{{statusOptions[statusIndex]}}</view>
    </picker>
    <view class="filter-actions">
      <button class="secondary-button filter-button" bindtap="resetFilters">{{text.reset}}</button>
      <button class="primary-button filter-button" bindtap="submitSearch">{{text.search}}</button>
    </view>
  </view>

  <view wx:if="{{loading}}" class="panel-card">
    <view class="empty-text">{{text.loading}}</view>
  </view>

  <view wx:elif="{{errorMessage}}" class="panel-card">
    <view class="empty-text">{{errorMessage}}</view>
  </view>

  <view wx:elif="{{!students.length}}" class="panel-card">
    <view class="empty-text">{{text.empty}}</view>
  </view>

  <view wx:else class="student-list">
    <view wx:for="{{students}}" wx:key="id" class="student-card {{item.groupToneClass}}">
      <view class="student-card-top">
        <view class="student-main">
          <view class="student-title-row">
            <text class="student-name">{{item.name}}</text>
            <text class="student-no">{{item.displayStudentNo}}</text>
          </view>
          <view class="student-meta-row">
            <text class="gender-badge {{item.displayGenderClass}}">{{item.displayGender}}</text>
            <text class="student-class">{{item.displayClassName}}</text>
          </view>
          <view wx:if="{{item.electiveClassText}}" class="elective-row">{{text.electiveClass}}{{item.electiveClassText}}</view>
        </view>
        <view class="status-badge">{{item.displayStatus}}</view>
      </view>
      <view class="student-action-row">
        <view class="student-action-button" data-student-id="{{item.id}}" data-student-name="{{item.name}}" bindtap="openAttendancePopup">{{text.attendanceRecord}}</view>
        <view class="student-action-button student-action-button-primary" data-student-id="{{item.id}}" bindtap="openEditPopup">{{text.editStudent}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{attendancePopupVisible}}" class="popup-mask" bindtap="closeAttendancePopup">
    <view class="popup-card" catchtap="noop">
      <view class="popup-title">{{attendancePopupTitle}}</view>
      <view wx:if="{{attendancePopupLoading}}" class="empty-text">{{text.loadingAttendance}}</view>
      <block wx:elif="{{attendanceStats}}">
        <view class="attendance-summary">
          <view class="attendance-stat">{{text.attendanceTotal}} {{attendanceStats.total || 0}} {{text.attendanceTimes}}</view>
          <view class="attendance-stat">{{text.present}} {{attendanceStats.present || 0}}</view>
          <view class="attendance-stat">{{text.absent}} {{attendanceStats.absent || 0}}</view>
          <view class="attendance-stat">{{text.leave}} {{attendanceStats.leave || 0}}</view>
          <view class="attendance-stat">{{text.rate}} {{attendanceStats.rate || '0.0'}}%</view>
        </view>
        <view wx:if="{{attendanceRecords.length}}" class="attendance-record-list">
          <view wx:for="{{attendanceRecords}}" wx:key="index" class="attendance-record-item">
            <text>{{item.date || '-'}}</text>
            <text class="attendance-record-status">{{item.status || '-'}}</text>
          </view>
        </view>
        <view wx:else class="empty-text">{{text.attendanceEmpty}}</view>
      </block>
      <view wx:else class="empty-text">{{text.attendanceEmpty}}</view>
      <button class="secondary-button popup-close-button" bindtap="closeAttendancePopup">{{text.close}}</button>
    </view>
  </view>

  <view wx:if="{{editPopupVisible}}" class="popup-mask" bindtap="closeEditPopup">
    <view class="popup-card" catchtap="noop">
      <view class="popup-title">{{text.editTitle}}</view>
      <view class="popup-form-grid">
        <view class="popup-form-item">
          <view class="popup-field-label">{{text.namePlaceholder}}</view>
          <input class="popup-input" type="text" placeholder="{{text.namePlaceholder}}" value="{{editName}}" bindinput="onEditNameInput"></input>
        </view>
        <view class="popup-form-item">
          <view class="popup-field-label">{{text.genderPlaceholder}}</view>
          <picker mode="selector" range="{{genderOptions}}" value="{{editGenderIndex}}" bindchange="onEditGenderChange">
            <view class="picker-field popup-picker">{{genderOptions[editGenderIndex]}}</view>
          </picker>
        </view>

        <view class="popup-form-item">
          <view class="popup-field-label">{{text.studentNoPlaceholder}}</view>
          <input class="popup-input" type="text" placeholder="{{text.studentNoPlaceholder}}" value="{{editStudentNo}}" bindinput="onEditStudentNoInput"></input>
        </view>
        <view class="popup-form-item">
          <view class="popup-field-label">{{text.idCardPlaceholder}}</view>
          <input class="popup-input" type="text" placeholder="{{text.idCardPlaceholder}}" value="{{editIdCard}}" bindinput="onEditIdCardInput"></input>
        </view>

        <view class="popup-form-item">
          <view class="popup-field-label">{{text.gradePlaceholder}}</view>
          <picker mode="selector" range="{{editGradeOptions}}" range-key="name" value="{{editGradeIndex}}" bindchange="onEditGradeChange">
            <view class="picker-field popup-picker">{{editGradeOptions[editGradeIndex].name}}</view>
          </picker>
        </view>
        <view class="popup-form-item">
          <view class="popup-field-label">{{text.classPlaceholder}}</view>
          <picker mode="selector" range="{{editClassOptions}}" range-key="name" value="{{editClassIndex}}" bindchange="onEditClassChange">
            <view class="picker-field popup-picker">{{editClassOptions[editClassIndex].name}}</view>
          </picker>
        </view>

        <view class="popup-form-item">
          <view class="popup-field-label">{{text.electiveClassPlaceholder}}</view>
          <picker mode="selector" range="{{editElectiveOptions}}" range-key="name" value="{{editElectiveIndex}}" bindchange="onEditElectiveClassChange">
            <view class="picker-field popup-picker">{{editElectiveOptions[editElectiveIndex].name}}</view>
          </picker>
        </view>
        <view class="popup-form-item">
          <view class="popup-field-label">{{text.statusPlaceholder}}</view>
          <picker mode="selector" range="{{editStatusOptions}}" value="{{editStatusIndex}}" bindchange="onEditStatusChange">
            <view class="picker-field popup-picker">{{editStatusOptions[editStatusIndex]}}</view>
          </picker>
        </view>
      </view>
      <view class="popup-action-row">
        <button class="secondary-button popup-action-button" bindtap="closeEditPopup">{{text.cancel}}</button>
        <button class="primary-button popup-action-button" loading="{{editSaving}}" bindtap="saveEditStudent">{{text.save}}</button>
      </view>
    </view>
  </view>
</view>
