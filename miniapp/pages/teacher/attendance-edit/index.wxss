.date-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 24rpx;
  background: #eef6ff;
  border: 1rpx solid rgba(74, 144, 226, 0.16);
  border-radius: 20rpx;
  color: #4a90e2;
}

.date-picker-main {
  min-width: 0;
}

.date-picker-label {
  font-size: 13px;
  color: #6b7a8c;
}

.date-picker-value {
  margin-top: 8rpx;
  font-size: 16px;
  font-weight: 700;
  color: #4a90e2;
}

.date-picker-arrow {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #4a90e2;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.stat-chip {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 14rpx 10rpx;
  border-radius: 18rpx;
  border: 1rpx solid transparent;
  background: transparent;
}

.stat-chip-active {
  border-width: 1rpx;
}

.stat-chip-present-active {
  background: rgba(39, 174, 96, 0.12);
  border-color: rgba(39, 174, 96, 0.46);
}

.stat-chip-absent-active {
  background: rgba(231, 76, 60, 0.12);
  border-color: rgba(231, 76, 60, 0.42);
}

.stat-chip-leave-active {
  background: rgba(41, 128, 185, 0.12);
  border-color: rgba(41, 128, 185, 0.42);
}

.stat-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.stat-dot-present {
  background: #27ae60;
}

.stat-dot-absent {
  background: #e74c3c;
}

.stat-dot-leave {
  background: #2980b9;
}

.stat-text {
  font-size: 13px;
  font-weight: 700;
}

.stat-text-present {
  color: #27ae60;
}

.stat-text-absent {
  color: #e74c3c;
}

.stat-text-leave {
  color: #2980b9;
}

.student-list {
  margin-top: 18rpx;
}

.attendance-empty-text {
  margin-top: 18rpx;
}

.student-item {
  padding: 24rpx 20rpx;
  margin-bottom: 14rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(22, 50, 79, 0.08);
}

.student-item:last-child {
  margin-bottom: 0;
}

.student-item-tone-a {
  background: #ddeeff;
  border-color: rgba(74, 144, 226, 0.22);
}

.student-item-tone-b {
  background: #ffe2c2;
  border-color: rgba(217, 119, 6, 0.22);
}

.student-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.student-info {
  flex: 1;
  min-width: 0;
}

.student-name {
  font-size: 16px;
  font-weight: 700;
  color: #16324f;
}

.student-meta {
  margin-top: 8rpx;
  font-size: 13px;
  color: #64748b;
}

.student-meta-inline {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.status-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.status-row-inline {
  flex-shrink: 0;
  margin-top: 0;
  justify-content: flex-end;
  gap: 10rpx;
}

.status-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 13px;
  border: 1rpx solid transparent;
  background: transparent;
  font-weight: 500;
}

.status-chip-active {
  color: #ffffff;
}

.status-chip-present {
  background: #27ae60;
  border-color: #27ae60;
}

.status-chip-absent {
  background: #e74c3c;
  border-color: #e74c3c;
}

.status-chip-leave {
  background: #2980b9;
  border-color: #2980b9;
}

.status-chip-present-ghost {
  color: #27ae60;
  border-color: #27ae60;
}

.status-chip-absent-ghost {
  color: #e74c3c;
  border-color: #e74c3c;
}

.status-chip-leave-ghost {
  color: #2980b9;
  border-color: #2980b9;
}

.save-button {
  margin-top: 28rpx;
}

