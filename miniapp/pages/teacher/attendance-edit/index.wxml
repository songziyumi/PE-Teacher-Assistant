<view class="page-shell">
  <view class="hero-card">
    <view class="page-title">{{className || '考勤登记'}}</view>
    <view class="page-subtitle">选择日期后，逐个学生切换出勤状态并保存。</view>
  </view>

  <view class="panel-card">
    <picker mode="date" value="{{date}}" bindchange="onDateChange">
      <view class="date-picker">
        <view class="date-picker-main">
          <view class="date-picker-label">登记日期</view>
          <view class="date-picker-value">{{date}}</view>
        </view>
        <view class="date-picker-arrow">▼</view>
      </view>
    </picker>
  </view>

  <view wx:if="{{loading}}" class="panel-card">
    <view class="empty-text">正在加载学生与考勤数据...</view>
  </view>

  <view wx:elif="{{errorMessage}}" class="panel-card">
    <view class="empty-text">{{errorMessage}}</view>
  </view>

  <view wx:elif="{{!allStudents.length}}" class="panel-card">
    <view class="empty-text">当前班级暂无学生。</view>
  </view>

  <view wx:else class="panel-card">
    <view class="stats-row">
      <view
        class="stat-chip {{selectedStatusFilter === '出勤' ? 'stat-chip-active stat-chip-present-active' : ''}}"
        data-status="出勤"
        bindtap="toggleStatusFilter"
      >
        <view class="stat-dot stat-dot-present"></view>
        <view class="stat-text stat-text-present">出勤 {{stats.present}}</view>
      </view>
      <view
        class="stat-chip {{selectedStatusFilter === '缺勤' ? 'stat-chip-active stat-chip-absent-active' : ''}}"
        data-status="缺勤"
        bindtap="toggleStatusFilter"
      >
        <view class="stat-dot stat-dot-absent"></view>
        <view class="stat-text stat-text-absent">缺勤 {{stats.absent}}</view>
      </view>
      <view
        class="stat-chip {{selectedStatusFilter === '请假' ? 'stat-chip-active stat-chip-leave-active' : ''}}"
        data-status="请假"
        bindtap="toggleStatusFilter"
      >
        <view class="stat-dot stat-dot-leave"></view>
        <view class="stat-text stat-text-leave">请假 {{stats.leave}}</view>
      </view>
    </view>

    <view class="section-title">学生列表</view>
    <view wx:if="{{!students.length}}" class="empty-text attendance-empty-text">{{emptyMessage}}</view>
    <view wx:else class="student-list">
      <view wx:for="{{students}}" wx:key="id" class="student-item {{item.groupToneClass}}">
        <view class="student-head">
          <view class="student-info">
            <view class="student-meta">
              <text class="student-name">{{item.name}}</text>
              <text wx:if="{{item.gender}}"> · {{item.gender}}</text>
            </view>
            <view class="student-meta student-meta-inline">
              <text>{{item.metaLine}}</text>
            </view>
          </view>
          <view class="status-row status-row-inline">
            <view
              wx:for="{{statusOptions}}"
              wx:key="value"
              wx:for-item="status"
              class="status-chip {{item.currentStatus === status.value ? 'status-chip-active' : ''}} {{item.currentStatus === status.value ? status.activeClass : status.ghostClass}}"
              data-student-id="{{item.id}}"
              data-status="{{status.value}}"
              bindtap="changeStatus"
            >
              {{status.value}}
            </view>
          </view>
        </view>
      </view>
    </view>

    <button class="primary-button save-button" loading="{{saving}}" bindtap="saveAttendance">保存考勤</button>
  </view>
</view>
