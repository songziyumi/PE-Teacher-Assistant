.hero-meta-row {
  margin-top: 22rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.hero-meta-pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #16324f;
  font-size: 13px;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.summary-card {
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f6fbff 100%);
  border: 1rpx solid rgba(22, 50, 79, 0.08);
  box-shadow: 0 16rpx 36rpx rgba(22, 50, 79, 0.06);
}

.summary-label {
  font-size: 13px;
  color: #64748b;
}

.summary-value {
  margin-top: 12rpx;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #16324f;
  word-break: break-all;
}

.summary-date {
  font-size: 16px;
}

.level-text {
  display: inline-flex;
  align-items: center;
}

.level-excellent {
  color: #16a34a;
  background: rgba(34, 197, 94, 0.14);
}

.level-good {
  color: #2563eb;
  background: rgba(37, 99, 235, 0.14);
}

.level-pass {
  color: #d97706;
  background: rgba(245, 158, 11, 0.16);
}

.level-fail {
  color: #dc2626;
  background: rgba(239, 68, 68, 0.14);
}

.level-empty {
  color: #64748b;
  background: rgba(100, 116, 139, 0.12);
}

.detail-list {
  margin-top: 16rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(22, 50, 79, 0.08);
}

.detail-item:last-child {
  border-bottom: 0;
}

.detail-item-multiline {
  align-items: flex-start;
}

.detail-label {
  font-size: 14px;
  color: #64748b;
}

.detail-main {
  flex: 1;
  min-width: 0;
}

.detail-inline-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  flex-wrap: wrap;
}

.detail-value {
  font-size: 26rpx;
  color: #16324f;
  font-weight: 600;
  word-break: break-all;
}

.detail-extra {
  font-size: 13px;
  color: #64748b;
}

.detail-level-badge {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.4;
}

