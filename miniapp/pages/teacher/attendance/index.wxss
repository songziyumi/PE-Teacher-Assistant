.class-list {
  margin-top: 18rpx;
}

.class-item {
  padding: 24rpx 22rpx;
  margin-bottom: 16rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #eef5fb 100%);
  border: 1rpx solid rgba(22, 50, 79, 0.08);
}

.class-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #16324f;
}

.class-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}
