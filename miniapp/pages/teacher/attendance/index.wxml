<view class="page-shell">
  <view class="hero-card">
    <view class="page-title">{{text.title}}</view>
    <view class="page-subtitle">{{text.subtitle}}</view>
  </view>

  <view wx:if="{{loading}}" class="panel-card">
    <view class="empty-text">{{text.loading}}</view>
  </view>

  <view wx:elif="{{errorMessage}}" class="panel-card">
    <view class="empty-text">{{errorMessage}}</view>
  </view>

  <view wx:elif="{{!classes.length}}" class="panel-card">
    <view class="empty-text">{{text.empty}}</view>
  </view>

  <view wx:else class="panel-card">
    <view class="section-title">{{text.sectionTitle}}</view>
    <view class="class-list">
      <view wx:for="{{classes}}" wx:key="id" class="class-item" data-class-id="{{item.id}}" data-class-name="{{item.name}}" bindtap="openClass">
        <view class="class-name">{{item.name}}</view>
        <view class="class-meta">
          {{item.gradeName || text.noGrade}}{{text.metaSeparator}}{{item.type || text.classType}}
        </view>
      </view>
    </view>
  </view>
</view>
