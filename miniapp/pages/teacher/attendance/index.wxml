<view class="page-shell">
  <view class="hero-card">
    <view class="page-title">教师点名</view>
    <view class="page-subtitle">先选择一个你负责的班级，再进入当日考勤登记。</view>
  </view>

  <view wx:if="{{loading}}" class="panel-card">
    <view class="empty-text">正在加载班级列表...</view>
  </view>

  <view wx:elif="{{errorMessage}}" class="panel-card">
    <view class="empty-text">{{errorMessage}}</view>
  </view>

  <view wx:elif="{{!classes.length}}" class="panel-card">
    <view class="empty-text">当前账号下还没有可点名的班级。</view>
  </view>

  <view wx:else class="panel-card">
    <view class="section-title">我的班级</view>
    <view class="class-list">
      <view wx:for="{{classes}}" wx:key="id" class="class-item" data-class-id="{{item.id}}" data-class-name="{{item.name}}" bindtap="openClass">
        <view class="class-name">{{item.name}}</view>
        <view class="class-meta">{{item.gradeName || '未分年级'}} · {{item.type || '班级'}}</view>
      </view>
    </view>
  </view>
</view>
