.profile-hero {
  background:
    linear-gradient(145deg, rgba(22, 50, 79, 0.94), rgba(44, 90, 135, 0.86)),
    #16324f;
}

.profile-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.profile-hero .page-title,
.profile-hero .page-subtitle {
  color: #ffffff;
}

.avatar-wrap {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  flex-shrink: 0;
}

.avatar-image,
.avatar-fallback {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
}

.avatar-image {
  background: rgba(255, 255, 255, 0.22);
}

.avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.16);
  border: 2rpx solid rgba(255, 255, 255, 0.28);
  font-size: 52rpx;
  font-weight: 700;
  color: #ffffff;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.profile-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.profile-tag {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
  color: #ffffff;
  max-width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.profile-metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 22rpx;
}

.profile-metric-card {
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.65), rgba(255, 255, 255, 0) 38%),
    linear-gradient(180deg, #eef5fb 0%, #e6eff8 100%);
  border: 1rpx solid rgba(22, 50, 79, 0.08);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.45);
}

.profile-metric-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.profile-metric-kicker {
  font-size: 20rpx;
  font-weight: 700;
  color: #4e6985;
  letter-spacing: 2rpx;
}

.profile-metric-label {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #5f7182;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-head-actions {
  justify-content: flex-end;
  margin-top: 16rpx;
}

.section-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 12rpx;
  width: 100%;
}

.mini-button {
  min-width: 0;
  width: auto;
  max-width: 180rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 14rpx;
  margin: 0;
  border-radius: 16rpx;
  font-size: 22rpx;
  box-sizing: border-box;
}

.mini-button::after {
  border: 0;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.info-card {
  min-width: 0;
  padding: 20rpx 18rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #eef5fb 100%);
  border: 1rpx solid rgba(22, 50, 79, 0.08);
}

.info-card-wide {
  grid-column: 1 / -1;
}

.info-card-label {
  font-size: 22rpx;
  color: #64748b;
}

.info-card-value {
  margin-top: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #16324f;
  line-height: 1.5;
  word-break: break-all;
}

.info-card-value-multiline {
  font-weight: 500;
  white-space: pre-wrap;
}

.field-label {
  margin-top: 18rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #35526f;
}

.input-field,
.input-like,
.textarea-field {
  width: 100%;
  box-sizing: border-box;
  background: #f8fbff;
  border: 1rpx solid rgba(22, 50, 79, 0.12);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #16324f;
}

.input-field,
.input-like {
  min-height: 92rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
}

.textarea-field {
  min-height: 180rpx;
  padding: 20rpx 24rpx;
}

.edit-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 26rpx;
}

.edit-button {
  flex: 1;
}

.security-summary {
  margin-top: 18rpx;
  padding: 24rpx 22rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #eef5fb 100%);
  border: 1rpx solid rgba(22, 50, 79, 0.08);
}

.security-pill {
  display: inline-block;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #16324f;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
}

.security-copy {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #506274;
}

.error-box {
  margin-top: 20rpx;
  padding: 20rpx 22rpx;
  background: #fff1f2;
  border-radius: 18rpx;
  color: #be123c;
  font-size: 24rpx;
  line-height: 1.6;
}

.activity-card {
  margin-top: 16rpx;
  padding: 22rpx 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #fbfdff 0%, #f2f7fc 100%);
  border: 1rpx solid rgba(22, 50, 79, 0.08);
}

.activity-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 14rpx;
}

.activity-badge {
  flex-shrink: 0;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #e6eef8;
  color: #315170;
  font-size: 20rpx;
  font-weight: 700;
}
