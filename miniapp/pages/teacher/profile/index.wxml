<view class="page-shell">
  <view wx:if="{{loading}}" class="panel-card">
    <view class="empty-text">{{text.loading}}</view>
  </view>

  <view wx:elif="{{errorMessage && !profile}}" class="panel-card">
    <view class="empty-text">{{errorMessage}}</view>
  </view>

  <block wx:else>
    <view class="hero-card profile-hero">
      <view class="profile-top">
        <view class="avatar-wrap">
          <image wx:if="{{profile.photoUrl}}" class="avatar-image" src="{{profile.photoUrl}}" mode="aspectFill"></image>
          <view wx:else class="avatar-fallback">{{profile.name ? profile.name.slice(0, 1) : text.avatarFallback}}</view>
        </view>

        <view class="profile-main">
          <view class="page-title">{{profile.name || text.teacherFallback}}</view>
          <view class="page-subtitle">{{profile.role || ''}}<text wx:if="{{profile.schoolName}}">{{text.schoolSeparator}}{{profile.schoolName}}</text></view>
          <view class="profile-tag-row">
            <view class="profile-tag">{{profile.bio || text.emptyBio}}</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{stats}}" class="panel-card">
      <view class="section-title">{{text.overviewTitle}}</view>
      <view class="profile-metrics-grid">
        <view class="profile-metric-card">
          <view class="profile-metric-top">
            <view class="profile-metric-kicker">{{text.metricClass}}</view>
          </view>
          <view class="metric-value">{{stats.classCount || 0}}</view>
          <view class="profile-metric-label">{{text.metricClassLabel}}</view>
        </view>
        <view class="profile-metric-card">
          <view class="profile-metric-top">
            <view class="profile-metric-kicker">{{text.metricAttendance}}</view>
          </view>
          <view class="metric-value">{{stats.monthlyAttendanceCount || 0}}</view>
          <view class="profile-metric-label">{{text.metricAttendanceLabel}}</view>
        </view>
        <view class="profile-metric-card">
          <view class="profile-metric-top">
            <view class="profile-metric-kicker">{{text.metricPending}}</view>
          </view>
          <view class="metric-value">{{stats.pendingRequestCount || 0}}</view>
          <view class="profile-metric-label">{{text.metricPendingLabel}}</view>
        </view>
        <view class="profile-metric-card">
          <view class="profile-metric-top">
            <view class="profile-metric-kicker">{{text.metricProcessed}}</view>
          </view>
          <view class="metric-value">{{stats.processedRequestCount || 0}}</view>
          <view class="profile-metric-label">{{text.metricProcessedLabel}}</view>
        </view>
      </view>
    </view>

    <view class="panel-card">
      <view class="section-title">{{text.basicTitle}}</view>
      <view class="section-head section-head-actions">
        <view class="section-actions">
          <button class="secondary-button mini-button" loading="{{uploadingPhoto}}" bindtap="choosePhoto">{{text.changePhoto}}</button>
          <button wx:if="{{!editingProfile}}" class="secondary-button mini-button" bindtap="startEdit">{{text.edit}}</button>
        </view>
      </view>

      <block wx:if="{{editingProfile}}">
        <view class="field-label">{{text.gender}}</view>
        <picker mode="selector" range="{{genderOptions}}" value="{{genderIndex >= 0 ? genderIndex : 0}}" bindchange="onGenderChange">
          <view class="input-like">{{genderIndex >= 0 ? genderOptions[genderIndex] : text.choose}}</view>
        </picker>

        <view class="field-label">{{text.birthDate}}</view>
        <picker mode="date" value="{{birthDate}}" bindchange="onBirthDateChange">
          <view class="input-like">{{birthDate || text.chooseDate}}</view>
        </picker>

        <view class="field-label">{{text.specialty}}</view>
        <input class="input-field" value="{{specialty}}" placeholder="{{text.specialtyPlaceholder}}" bindinput="onSpecialtyInput" />

        <view class="field-label">{{text.email}}</view>
        <input class="input-field" value="{{email}}" placeholder="{{text.emailPlaceholder}}" bindinput="onEmailInput" />

        <view class="field-label">{{text.bio}}</view>
        <textarea class="textarea-field" value="{{bio}}" placeholder="{{text.bioPlaceholder}}" bindinput="onBioInput"></textarea>

        <view class="edit-actions">
          <button class="secondary-button edit-button" bindtap="cancelEdit">{{text.cancel}}</button>
          <button class="primary-button edit-button" loading="{{saving}}" bindtap="saveProfile">{{text.save}}</button>
        </view>
      </block>

      <block wx:else>
        <view class="info-grid">
          <view class="info-card">
            <view class="info-card-label">{{text.username}}</view>
            <view class="info-card-value">{{profile.username || '-'}}</view>
          </view>
          <view class="info-card">
            <view class="info-card-label">{{text.gender}}</view>
            <view class="info-card-value">{{profile.gender || '-'}}</view>
          </view>
          <view class="info-card">
            <view class="info-card-label">{{text.birthDate}}</view>
            <view class="info-card-value">{{profile.birthDate || '-'}}</view>
          </view>
          <view class="info-card">
            <view class="info-card-label">{{text.specialty}}</view>
            <view class="info-card-value">{{profile.specialty || '-'}}</view>
          </view>
          <view class="info-card info-card-wide">
            <view class="info-card-label">{{text.email}}</view>
            <view class="info-card-value">{{profile.email || '-'}}</view>
          </view>
          <view class="info-card info-card-wide">
            <view class="info-card-label">{{text.bio}}</view>
            <view class="info-card-value info-card-value-multiline">{{profile.bio || '-'}}</view>
          </view>
        </view>
      </block>
    </view>

    <view class="panel-card">
      <view class="section-head">
        <view class="section-title">{{text.securityTitle}}</view>
        <button class="secondary-button mini-button" bindtap="togglePasswordForm">
          {{showPasswordForm ? text.collapse : text.changePassword}}
        </button>
      </view>

      <view wx:if="{{errorMessage}}" class="error-box">{{errorMessage}}</view>

      <view wx:if="{{!showPasswordForm}}" class="security-summary">
        <view class="security-pill">{{text.passwordPill}}</view>
        <view class="security-copy">{{text.passwordHint}}</view>
      </view>

      <view wx:if="{{showPasswordForm}}">
        <view class="field-label">{{text.oldPassword}}</view>
        <input password="{{true}}" class="input-field" value="{{oldPassword}}" placeholder="{{text.oldPasswordPlaceholder}}" bindinput="onOldPasswordInput" />

        <view class="field-label">{{text.newPassword}}</view>
        <input password="{{true}}" class="input-field" value="{{newPassword}}" placeholder="{{text.newPasswordPlaceholder}}" bindinput="onNewPasswordInput" />

        <view class="field-label">{{text.confirmPassword}}</view>
        <input password="{{true}}" class="input-field" value="{{confirmPassword}}" placeholder="{{text.confirmPasswordPlaceholder}}" bindinput="onConfirmPasswordInput" />

        <button class="primary-button" loading="{{changingPassword}}" bindtap="changePassword">{{text.submitChange}}</button>
      </view>
    </view>

    <view wx:if="{{stats && stats.recentActivities && stats.recentActivities.length}}" class="panel-card">
      <view class="section-title">{{text.recentTitle}}</view>
      <view wx:for="{{stats.recentActivities}}" wx:key="index" class="activity-card">
        <view class="activity-top">
          <view class="message-subject">{{item.courseName || item.action || text.approvalRecord}}</view>
          <view class="activity-badge">{{item.action || text.activityFallback}}</view>
        </view>
        <view class="message-meta">{{item.studentName || '-'}}<text wx:if="{{item.time}}">{{text.activitySeparator}}{{item.time}}</text></view>
        <view wx:if="{{item.remark}}" class="message-meta">{{item.remark}}</view>
      </view>
    </view>
  </block>
</view>
