<view class="page-shell">
  <view wx:if="{{loading}}" class="panel-card">
    <view class="empty-text">正在加载个人主页...</view>
  </view>

  <view wx:elif="{{errorMessage && !profile}}" class="panel-card">
    <view class="empty-text">{{errorMessage}}</view>
  </view>

  <block wx:else>
    <view class="hero-card profile-hero">
      <view class="profile-top">
        <view class="avatar-wrap">
          <image wx:if="{{profile.photoUrl}}" class="avatar-image" src="{{profile.photoUrl}}" mode="aspectFill"></image>
          <view wx:else class="avatar-fallback">{{profile.name ? profile.name.slice(0, 1) : '师'}}</view>
        </view>

        <view class="profile-main">
          <view class="page-title">{{profile.name || '教师'}}</view>
          <view class="page-subtitle">{{profile.role || ''}}<text wx:if="{{profile.schoolName}}"> · {{profile.schoolName}}</text></view>
          <view class="profile-tag-row">
            <view class="profile-tag">{{profile.bio || '未填写教师简介'}}</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{stats}}" class="panel-card">
      <view class="section-title">概览统计</view>
      <view class="profile-metrics-grid">
        <view class="profile-metric-card">
          <view class="profile-metric-top">
            <view class="profile-metric-kicker">班务</view>
          </view>
          <view class="metric-value">{{stats.classCount || 0}}</view>
          <view class="profile-metric-label">班级数</view>
        </view>
        <view class="profile-metric-card">
          <view class="profile-metric-top">
            <view class="profile-metric-kicker">出勤</view>
          </view>
          <view class="metric-value">{{stats.monthlyAttendanceCount || 0}}</view>
          <view class="profile-metric-label">本月点名天数</view>
        </view>
        <view class="profile-metric-card">
          <view class="profile-metric-top">
            <view class="profile-metric-kicker">审批</view>
          </view>
          <view class="metric-value">{{stats.pendingRequestCount || 0}}</view>
          <view class="profile-metric-label">待审批</view>
        </view>
        <view class="profile-metric-card">
          <view class="profile-metric-top">
            <view class="profile-metric-kicker">处理</view>
          </view>
          <view class="metric-value">{{stats.processedRequestCount || 0}}</view>
          <view class="profile-metric-label">已处理审批</view>
        </view>
      </view>
    </view>

    <view class="panel-card">
      <view class="section-title">基本资料</view>
      <view class="section-head section-head-actions">
        <view class="section-actions">
          <button class="secondary-button mini-button" loading="{{uploadingPhoto}}" bindtap="choosePhoto">换头像</button>
          <button wx:if="{{!editingProfile}}" class="secondary-button mini-button" bindtap="startEdit">编辑</button>
        </view>
      </view>

      <block wx:if="{{editingProfile}}">
        <view class="field-label">性别</view>
        <picker mode="selector" range="{{genderOptions}}" value="{{genderIndex >= 0 ? genderIndex : 0}}" bindchange="onGenderChange">
          <view class="input-like">{{genderIndex >= 0 ? genderOptions[genderIndex] : '请选择'}}</view>
        </picker>

        <view class="field-label">出生日期</view>
        <picker mode="date" value="{{birthDate}}" bindchange="onBirthDateChange">
          <view class="input-like">{{birthDate || '请选择日期'}}</view>
        </picker>

        <view class="field-label">专项</view>
        <input class="input-field" value="{{specialty}}" placeholder="请输入专项" bindinput="onSpecialtyInput" />

        <view class="field-label">邮箱</view>
        <input class="input-field" value="{{email}}" placeholder="请输入邮箱" bindinput="onEmailInput" />

        <view class="field-label">简介</view>
        <textarea class="textarea-field" value="{{bio}}" placeholder="介绍一下自己" bindinput="onBioInput"></textarea>

        <view class="edit-actions">
          <button class="secondary-button edit-button" bindtap="cancelEdit">取消</button>
          <button class="primary-button edit-button" loading="{{saving}}" bindtap="saveProfile">保存</button>
        </view>
      </block>

      <block wx:else>
        <view class="info-grid">
          <view class="info-card">
            <view class="info-card-label">账号</view>
            <view class="info-card-value">{{profile.username || '-'}}</view>
          </view>
          <view class="info-card">
            <view class="info-card-label">性别</view>
            <view class="info-card-value">{{profile.gender || '-'}}</view>
          </view>
          <view class="info-card">
            <view class="info-card-label">出生日期</view>
            <view class="info-card-value">{{profile.birthDate || '-'}}</view>
          </view>
          <view class="info-card">
            <view class="info-card-label">专项</view>
            <view class="info-card-value">{{profile.specialty || '-'}}</view>
          </view>
          <view class="info-card info-card-wide">
            <view class="info-card-label">邮箱</view>
            <view class="info-card-value">{{profile.email || '-'}}</view>
          </view>
          <view class="info-card info-card-wide">
            <view class="info-card-label">简介</view>
            <view class="info-card-value info-card-value-multiline">{{profile.bio || '-'}}</view>
          </view>
        </view>
      </block>
    </view>

    <view class="panel-card">
      <view class="section-head">
        <view class="section-title">账号安全</view>
        <button class="secondary-button mini-button" bindtap="togglePasswordForm">
          {{showPasswordForm ? '收起' : '修改密码'}}
        </button>
      </view>

      <view wx:if="{{errorMessage}}" class="error-box">{{errorMessage}}</view>

      <view wx:if="{{!showPasswordForm}}" class="security-summary">
        <view class="security-pill">密码保护</view>
        <view class="security-copy">建议定期更新密码，避免长期使用固定口令。</view>
      </view>

      <view wx:if="{{showPasswordForm}}">
        <view class="field-label">旧密码</view>
        <input password="{{true}}" class="input-field" value="{{oldPassword}}" placeholder="请输入旧密码" bindinput="onOldPasswordInput" />

        <view class="field-label">新密码</view>
        <input password="{{true}}" class="input-field" value="{{newPassword}}" placeholder="请输入新密码" bindinput="onNewPasswordInput" />

        <view class="field-label">确认新密码</view>
        <input password="{{true}}" class="input-field" value="{{confirmPassword}}" placeholder="请再次输入新密码" bindinput="onConfirmPasswordInput" />

        <button class="primary-button" loading="{{changingPassword}}" bindtap="changePassword">提交修改</button>
      </view>
    </view>

    <view wx:if="{{stats && stats.recentActivities && stats.recentActivities.length}}" class="panel-card">
      <view class="section-title">最近审批动态</view>
      <view wx:for="{{stats.recentActivities}}" wx:key="index" class="activity-card">
        <view class="activity-top">
          <view class="message-subject">{{item.courseName || item.action || '审批记录'}}</view>
          <view class="activity-badge">{{item.action || '动态'}}</view>
        </view>
        <view class="message-meta">{{item.studentName || '-'}}<text wx:if="{{item.time}}"> · {{item.time}}</text></view>
        <view wx:if="{{item.remark}}" class="message-meta">{{item.remark}}</view>
      </view>
    </view>
  </block>
</view>
