.filter-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.filter-item-full {
  grid-column: 1 / -1;
}

.filter-action-row {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.filter-action-button {
  width: 100%;
}

.hero-stats-grid {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.hero-stat-card {
  padding: 18rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(22, 50, 79, 0.08);
}

.hero-stat-label {
  font-size: 13px;
  color: #64748b;
}

.hero-stat-value {
  margin-top: 8rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #16324f;
}

.hero-overview-button {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 18rpx;
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  border: 1rpx solid rgba(22, 50, 79, 0.18);
  background: #ffffff;
  color: #16324f;
  font-size: 16px;
  font-weight: 600;
  text-align: center;
  line-height: 1.4;
  white-space: nowrap;
}

.filter-label {
  margin-bottom: 10rpx;
  font-size: 13px;
  color: #64748b;
}

.filter-input,
.filter-picker {
  min-height: 84rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  border-radius: 18rpx;
  background: #f8fbff;
  border: 1rpx solid rgba(22, 50, 79, 0.12);
  color: #16324f;
  font-size: 26rpx;
  box-sizing: border-box;
}

.project-tabs {
  margin-top: 18rpx;
  white-space: nowrap;
}

.project-tab-row {
  display: inline-flex;
  gap: 12rpx;
}

.project-tab {
  flex: none;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #eef5fb;
  color: #3c4a59;
  font-size: 14px;
}

.project-tab-active {
  background: #16324f;
  color: #ffffff;
}

.current-project-tip {
  margin-top: 18rpx;
  font-size: 14px;
  color: #3c4a59;
}

.filter-switch-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.filter-switch-label {
  font-size: 14px;
  color: #16324f;
}

.student-list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin: 22rpx 4rpx 16rpx;
}

.student-list-title {
  margin: 0;
}

.student-list-count {
  font-size: 13px;
  color: #64748b;
}

.student-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.student-item-card {
  padding: 22rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(22, 50, 79, 0.08);
  box-shadow: 0 12rpx 28rpx rgba(22, 50, 79, 0.06);
}

.student-item-top {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.student-summary {
  width: 100%;
}

.student-item-name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.student-item-name {
  font-size: 16px;
  font-weight: 700;
  color: #16324f;
}

.gender-badge {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(22, 50, 79, 0.08);
  color: #16324f;
  font-size: 20rpx;
}

.student-no-inline {
  font-size: 13px;
  color: #64748b;
  min-width: 0;
}

.student-detail-link {
  font-size: 13px;
  color: #2563eb;
  padding: 4rpx 0;
}

.student-input-inline {
  width: 200rpx;
  margin-left: auto;
}

.score-input {
  min-height: 84rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: #f8fbff;
  border: 1rpx solid rgba(22, 50, 79, 0.14);
  font-size: 16px;
  color: #16324f;
  box-sizing: border-box;
}

.score-input-inline {
  min-height: 68rpx;
  padding: 0 18rpx;
  font-size: 14px;
}

.not-applicable-inline {
  margin-left: auto;
  font-size: 13px;
  color: #94a3b8;
}

.bottom-save-bar {
  position: sticky;
  bottom: 0;
  z-index: 5;
  margin-top: 20rpx;
  padding: 20rpx 0 calc(8rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(244, 247, 251, 0) 0%, #f4f7fb 28rpx, #f4f7fb 100%);
}

.bottom-save-button {
  width: 100%;
}

