                <elementProp name="" elementType="Header">
                  <stringProp name="Header.name">Accept</stringProp>
                  <stringProp name="Header.value">application/json</stringProp>
                </elementProp>
              </collectionProp>
            </HeaderManager>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="йҺ»ж„¬еҪҮеЁІиҜІе§©ж·Үв„ғдј…" enabled="true">
              <stringProp name="cacheKey">extract-current-event</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script"><![CDATA[
import groovy.json.JsonSlurper

def root = new JsonSlurper().parseText(prev.getResponseDataAsString())
vars.put('eventCode', String.valueOf(root.code))
vars.put('eventStatus', root?.data?.status ? String.valueOf(root.data.status) : '')
vars.put('eventId', root?.data?.id ? String.valueOf(root.data.id) : '')
vars.put('inRound2', root?.data?.inRound2 == null ? '' : String.valueOf(root.data.inRound2))
prev.setResponseMessage("eventId=${vars.get('eventId')}, eventStatus=${vars.get('eventStatus')}, inRound2=${vars.get('inRound2')}")
              ]]></stringProp>
            </JSR223PostProcessor>
            <hashTree/>
            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="йҸӮо…Ўв–Ҳ-еЁІиҜІе§©жҫ¶еӢӘз°¬ ROUND2" enabled="true">
              <stringProp name="cacheKey">assert-event-round2</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script"><![CDATA[
if (vars.get('eventCode') != '200' || vars.get('eventStatus') != 'ROUND2' || vars.get('inRound2') != 'true') {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage('иӨ°ж’іеў еЁІиҜІе§©ж¶“е¶…ж№Ә ROUND2: ' + prev.getResponseDataAsString())
}
              ]]></stringProp>
            </JSR223Assertion>
            <hashTree/>
          </hashTree>
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="03 йҚҷоҲһвӮ¬еӨҺоҮіз»Ӣе¬ӘеһӘзҗӣ? enabled="true">
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="йҗўг„ҰеҹӣзҖ№ж°«з®ҹйҗЁеӢ«еҪүй–І? enabled="true">
              <collectionProp name="Arguments.arguments"/>
            </elementProp>
            <stringProp name="HTTPSampler.path">/api/student/courses</stringProp>
            <stringProp name="HTTPSampler.method">GET</stringProp>
            <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
            <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
            <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
