            <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
          </HTTPSamplerProxy>
          <hashTree>
            <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="й–ҙеӯҳжҪҲз’Үй”Ӣзң°жҫ¶?з’Үеү§в–јйҚ’жҘ„гҖғ" enabled="true">
              <collectionProp name="HeaderManager.headers">
                <elementProp name="" elementType="Header">
                  <stringProp name="Header.name">Authorization</stringProp>
                  <stringProp name="Header.value">Bearer ${token}</stringProp>
                </elementProp>
                <elementProp name="" elementType="Header">
                  <stringProp name="Header.name">Accept</stringProp>
                  <stringProp name="Header.value">application/json</stringProp>
                </elementProp>
              </collectionProp>
            </HeaderManager>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="з‘ҷпҪҶзҖҪйҗ©оҶҪзҲЈз’Үеү§в–ј" enabled="true">
              <stringProp name="cacheKey">resolve-target-course</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script"><![CDATA[
import groovy.json.JsonSlurper

def root = new JsonSlurper().parseText(prev.getResponseDataAsString())
def courses = root?.data ?: []
def targetId = (props.get('targetCourseId') ?: '').trim()
def targetName = (props.get('targetCourseName') ?: '').trim()
if (!targetName) {
    targetName = 'з“’еҙҮжӮҶ'
}

def matched = null
if (targetId) {
    matched = courses.find { String.valueOf(it.id) == targetId }
}
if (matched == null) {
    matched = courses.find { String.valueOf(it.name) == targetName }
}

vars.put('courseListCode', String.valueOf(root.code))
vars.put('resolvedCourseId', matched == null ? '' : String.valueOf(matched.id))
vars.put('resolvedCourseName', matched == null ? '' : String.valueOf(matched.name))
prev.setResponseMessage("resolvedCourseId=${vars.get('resolvedCourseId')}, resolvedCourseName=${vars.get('resolvedCourseName')}")
              ]]></stringProp>
            </JSR223PostProcessor>
            <hashTree/>
            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="йҸӮо…Ўв–Ҳ-йҗ©оҶҪзҲЈз’Үеү§в–јзҖӣжЁәж№Ә" enabled="true">
              <stringProp name="cacheKey">assert-course-found</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script"><![CDATA[
if (vars.get('courseListCode') != '200' || !vars.get('resolvedCourseId')) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage('йҗ©оҶҪзҲЈз’Үеү§в–јж¶“е¶…з“ЁйҚҰг„ҰеһЁз’Үеү§в–јйҺәгғҘеҪӣжҫ¶иҫ«и§Ұ: ' + prev.getResponseDataAsString())
}
              ]]></stringProp>
            </JSR223Assertion>
            <hashTree/>
          </hashTree>
          <SynchronizingTimer guiclass="TestBeanGUI" testclass="SynchronizingTimer" testname="04 йӘһи·әеҪӮзҖөеҪ’з¶Ҳ" enabled="true">
            <stringProp name="groupSize">${__P(syncUsers,120)}</stringProp>
            <stringProp name="timeoutInMs">${__P(syncTimeoutMs,15000)}</stringProp>
          </SynchronizingTimer>
          <hashTree/>
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="05 йҺ»ж„Әж°ҰйҺ¶гҲЈоҮі" enabled="true">
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="йҗўг„ҰеҹӣзҖ№ж°«з®ҹйҗЁеӢ«еҪүй–І? enabled="true">
              <collectionProp name="Arguments.arguments"/>
            </elementProp>
            <stringProp name="HTTPSampler.path">/api/student/courses/${resolvedCourseId}/select</stringProp>
            <stringProp name="HTTPSampler.method">POST</stringProp>
            <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
