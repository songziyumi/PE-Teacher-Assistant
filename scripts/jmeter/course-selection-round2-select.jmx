            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="йҺ»ж„¬еҪҮйҗ§иҜІз¶Қжө гӮҮеўқ" enabled="true">
              <stringProp name="cacheKey">extract-login-token</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script"><![CDATA[
import groovy.json.JsonSlurper

def root = new JsonSlurper().parseText(prev.getResponseDataAsString())
vars.put('loginCode', String.valueOf(root.code))
vars.put('loginMessage', String.valueOf(root.message))
vars.put('token', root?.data?.token ? String.valueOf(root.data.token) : '')
vars.put('mustChangePassword', root?.data?.mustChangePassword == null ? '' : String.valueOf(root.data.mustChangePassword))
prev.setResponseMessage("loginCode=${vars.get('loginCode')}, mustChangePassword=${vars.get('mustChangePassword')}")
              ]]></stringProp>
            </JSR223PostProcessor>
            <hashTree/>
            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="йҸӮо…Ўв–Ҳ-йҗ§иҜІз¶ҚйҺҙж„¬е§ӣ" enabled="true">
              <stringProp name="cacheKey">assert-login-ok</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script"><![CDATA[
if (vars.get('loginCode') != '200' || !vars.get('token')) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage('йҗ§иҜІз¶Қжҫ¶иҫ«и§Ұ: ' + prev.getResponseDataAsString())
}
              ]]></stringProp>
            </JSR223Assertion>
            <hashTree/>
          </hashTree>
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="02 иӨ°ж’іеў еЁІиҜІе§©" enabled="true">
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="йҗўг„ҰеҹӣзҖ№ж°«з®ҹйҗЁеӢ«еҪүй–І? enabled="true">
              <collectionProp name="Arguments.arguments"/>
            </elementProp>
            <stringProp name="HTTPSampler.path">/api/student/events/current</stringProp>
            <stringProp name="HTTPSampler.method">GET</stringProp>
            <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
