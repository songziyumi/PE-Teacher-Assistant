          <hashTree>
            <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="й–ҙеӯҳжҪҲз’Үй”Ӣзң°жҫ¶?иӨ°ж’іеў еЁІиҜІе§©" enabled="true">
