            <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
            <stringProp name="HTTPSampler.embedded_url_re"></stringProp>
          </HTTPSamplerProxy>
          <hashTree>
            <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="й–ҙеӯҳжҪҲз’Үй”Ӣзң°жҫ¶?йҺ»ж„Әж°ҰйҺ¶гҲЈоҮі" enabled="true">
              <collectionProp name="HeaderManager.headers">
                <elementProp name="" elementType="Header">
                  <stringProp name="Header.name">Authorization</stringProp>
                  <stringProp name="Header.value">Bearer ${token}</stringProp>
                </elementProp>
                <elementProp name="" elementType="Header">
                  <stringProp name="Header.name">Accept</stringProp>
                  <stringProp name="Header.value">application/json</stringProp>
                </elementProp>
              </collectionProp>
            </HeaderManager>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="з’Ғжқҝз¶Қж¶“ж°¬е§ҹжқ©ж–ҝжҙ–йҗ®? enabled="true">
              <stringProp name="cacheKey">extract-select-result</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script"><![CDATA[
import groovy.json.JsonSlurper

def root = new JsonSlurper().parseText(prev.getResponseDataAsString())
vars.put('selectCode', String.valueOf(root.code))
vars.put('selectMessage', root?.message ? String.valueOf(root.message) : '')
if (prev.getResponseCode() == '400' && vars.get('selectCode')) {
    prev.setSuccessful(true)
}
prev.setResponseMessage("bizCode=${vars.get('selectCode')}, bizMessage=${vars.get('selectMessage')}, course=${vars.get('resolvedCourseName')}, student=${vars.get('student_no')}")
              ]]></stringProp>
            </JSR223PostProcessor>
            <hashTree/>
          </hashTree>
        </hashTree>
      </hashTree>
    </hashTree>
  </hashTree>
